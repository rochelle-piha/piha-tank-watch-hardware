// Sync the clock so TLS can validate cert dates (mirrors the firmware's gate).
static bool syncClock() {
  configTime(0, 0, "pool.ntp.org", "time.nist.gov", "time.google.com");
  Serial.print("SNTP sync");
  unsigned long t0 = millis();
  while (time(nullptr) < 1577836800L && millis() - t0 < 15000UL) { delay(200); Serial.print("."); }
  bool ok = time(nullptr) >= 1577836800L;
  Serial.printf(" %s (epoch=%ld)\n", ok ? "OK" : "TIMEOUT", (long)time(nullptr));
  return ok;
}

// Returns the HTTP code (>0 = TLS handshake succeeded and a response came back;
// <=0 = connection/handshake refused).
static int probe(const char* label, const char* caCert, bool expectReachable) {
  Serial.printf("\n--- %s ---\n", label);
  IPAddress resolved;
  if (!WiFi.hostByName(API_HOST, resolved)) { Serial.println("DNS FAILED"); return -999; }
  Serial.printf("DNS %s -> %s\n", API_HOST, resolved.toString().c_str());

  WiFiClientSecure client;
  client.setCACert(caCert);
  HTTPClient http;
  http.setTimeout(12000);
  http.begin(client, API_URL);
  http.addHeader("Content-Type", "application/json");
  http.addHeader("x-api-key", "test:test");
  int code = http.POST("{\"email\":\"test@test.com\"}");
  Serial.printf("HTTP result: %d\n", code);
  if (code > 0) Serial.printf("Response: %s\n", http.getString().c_str());
  http.end();
  Serial.printf("Free heap: %u\n", ESP.getFreeHeap());

  bool reachable = code > 0;
  bool pass = (reachable == expectReachable);
  Serial.printf("%s  (expected %s)\n", pass ? "PASS" : "*** FAIL ***",
                expectReachable ? "reachable over validated TLS" : "REFUSED (wrong CA)");
  return code;
}

void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("\n=== TLS cert-validation bench harness (#189) ===");

  WiFi.mode(WIFI_STA);
  WiFi.begin(WIFI_SSID, WIFI_PASS);
  Serial.print("Connecting");
  for (int i = 0; i < 20 && WiFi.status() != WL_CONNECTED; i++) { delay(500); Serial.print("."); }
  Serial.println();
  if (WiFi.status() != WL_CONNECTED) { Serial.println("WiFi connect failed — check SSID/pass"); return; }
  Serial.printf("Connected: %s\n", WiFi.localIP().toString().c_str());

  if (!syncClock()) {
    Serial.println("Clock not synced — TLS validation would fail closed. Fix NTP reachability first.");
    return;
  }

  // POSITIVE: real bundle → must reach the API over a validated connection.
  probe("POSITIVE: Amazon root bundle (validated)", AMAZON_ROOT_CA_BUNDLE, true);
  // NEGATIVE: wrong CA → handshake must be refused. If this says "reachable",
  // validation is NOT actually on — do not ship.
  probe("NEGATIVE: wrong CA ISRG X1 (must refuse)", WRONG_CA_ISRG_X1, false);

  Serial.println("\n=== done — both must say PASS ===");
}

void loop() {}
